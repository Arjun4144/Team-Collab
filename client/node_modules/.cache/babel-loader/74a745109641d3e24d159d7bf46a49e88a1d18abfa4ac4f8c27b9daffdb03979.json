{"ast":null,"code":"import{useEffect}from'react';import useStore from'../store/useStore';export const useSocket=socket=>{useEffect(()=>{if(!socket)return;const onNewMessage=msg=>useStore.getState().addMessage(msg);const onResolved=msg=>useStore.getState().updateMessage(msg);const onTaskUp=task=>useStore.getState().updateTask(task);const onDecision=d=>useStore.getState().addDecision(d);const onTypingStart=_ref=>{let{userId,userName,channelId}=_ref;useStore.getState().setTyping(channelId,userId,userName,true);};const onTypingStop=_ref2=>{let{userId,channelId}=_ref2;useStore.getState().setTyping(channelId,userId,null,false);};socket.on('message:new',onNewMessage);socket.on('message:resolved',onResolved);socket.on('task:updated',onTaskUp);socket.on('decision:new',onDecision);socket.on('typing:start',onTypingStart);socket.on('typing:stop',onTypingStop);return()=>{socket.off('message:new',onNewMessage);socket.off('message:resolved',onResolved);socket.off('task:updated',onTaskUp);socket.off('decision:new',onDecision);socket.off('typing:start',onTypingStart);socket.off('typing:stop',onTypingStop);};},[socket]);};","map":{"version":3,"names":["useEffect","useStore","useSocket","socket","onNewMessage","msg","getState","addMessage","onResolved","updateMessage","onTaskUp","task","updateTask","onDecision","d","addDecision","onTypingStart","_ref","userId","userName","channelId","setTyping","onTypingStop","_ref2","on","off"],"sources":["C:/Users/arjun/Desktop/nexus/client/src/hooks/useSocket.js"],"sourcesContent":["import { useEffect } from 'react';\nimport useStore from '../store/useStore';\n\nexport const useSocket = (socket) => {\n  useEffect(() => {\n    if (!socket) return;\n\n    const onNewMessage = (msg) => useStore.getState().addMessage(msg);\n    const onResolved   = (msg) => useStore.getState().updateMessage(msg);\n    const onTaskUp     = (task) => useStore.getState().updateTask(task);\n    const onDecision   = (d)   => useStore.getState().addDecision(d);\n    const onTypingStart = ({ userId, userName, channelId }) => {\n      useStore.getState().setTyping(channelId, userId, userName, true);\n    };\n    const onTypingStop = ({ userId, channelId }) => {\n      useStore.getState().setTyping(channelId, userId, null, false);\n    };\n\n    socket.on('message:new',      onNewMessage);\n    socket.on('message:resolved', onResolved);\n    socket.on('task:updated',     onTaskUp);\n    socket.on('decision:new',     onDecision);\n    socket.on('typing:start',     onTypingStart);\n    socket.on('typing:stop',      onTypingStop);\n\n    return () => {\n      socket.off('message:new',      onNewMessage);\n      socket.off('message:resolved', onResolved);\n      socket.off('task:updated',     onTaskUp);\n      socket.off('decision:new',     onDecision);\n      socket.off('typing:start',     onTypingStart);\n      socket.off('typing:stop',      onTypingStop);\n    };\n  }, [socket]);\n};\n"],"mappings":"AAAA,OAASA,SAAS,KAAQ,OAAO,CACjC,MAAO,CAAAC,QAAQ,KAAM,mBAAmB,CAExC,MAAO,MAAM,CAAAC,SAAS,CAAIC,MAAM,EAAK,CACnCH,SAAS,CAAC,IAAM,CACd,GAAI,CAACG,MAAM,CAAE,OAEb,KAAM,CAAAC,YAAY,CAAIC,GAAG,EAAKJ,QAAQ,CAACK,QAAQ,CAAC,CAAC,CAACC,UAAU,CAACF,GAAG,CAAC,CACjE,KAAM,CAAAG,UAAU,CAAMH,GAAG,EAAKJ,QAAQ,CAACK,QAAQ,CAAC,CAAC,CAACG,aAAa,CAACJ,GAAG,CAAC,CACpE,KAAM,CAAAK,QAAQ,CAAQC,IAAI,EAAKV,QAAQ,CAACK,QAAQ,CAAC,CAAC,CAACM,UAAU,CAACD,IAAI,CAAC,CACnE,KAAM,CAAAE,UAAU,CAAMC,CAAC,EAAOb,QAAQ,CAACK,QAAQ,CAAC,CAAC,CAACS,WAAW,CAACD,CAAC,CAAC,CAChE,KAAM,CAAAE,aAAa,CAAGC,IAAA,EAAqC,IAApC,CAAEC,MAAM,CAAEC,QAAQ,CAAEC,SAAU,CAAC,CAAAH,IAAA,CACpDhB,QAAQ,CAACK,QAAQ,CAAC,CAAC,CAACe,SAAS,CAACD,SAAS,CAAEF,MAAM,CAAEC,QAAQ,CAAE,IAAI,CAAC,CAClE,CAAC,CACD,KAAM,CAAAG,YAAY,CAAGC,KAAA,EAA2B,IAA1B,CAAEL,MAAM,CAAEE,SAAU,CAAC,CAAAG,KAAA,CACzCtB,QAAQ,CAACK,QAAQ,CAAC,CAAC,CAACe,SAAS,CAACD,SAAS,CAAEF,MAAM,CAAE,IAAI,CAAE,KAAK,CAAC,CAC/D,CAAC,CAEDf,MAAM,CAACqB,EAAE,CAAC,aAAa,CAAOpB,YAAY,CAAC,CAC3CD,MAAM,CAACqB,EAAE,CAAC,kBAAkB,CAAEhB,UAAU,CAAC,CACzCL,MAAM,CAACqB,EAAE,CAAC,cAAc,CAAMd,QAAQ,CAAC,CACvCP